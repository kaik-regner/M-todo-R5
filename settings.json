    <script>
        const canvas = document.getElementById("space");
        const ctx = canvas.getContext("2d");
        let cw = canvas.width = window.innerWidth;
        let ch = canvas.height = window.innerHeight;
        const numStars = 400;
        const stars = [];
        
        for (let i = 0; i < numStars; i++) {
            stars.push({
                x: Math.random() * cw - cw / 2,
                y: Math.random() * ch - ch / 2,
                z: Math.random() * cw
            });
        }
        
        function draw() {
            ctx.fillStyle = "rgba(3, 3, 5, 0.3)";
            ctx.fillRect(0, 0, cw, ch);
            const cx = cw / 2;
            const cy = ch / 2;
            
            for (let i = 0; i < numStars; i++) {
                const star = stars[i];
                star.z -= 0.5; // Velocidade das estrelas
                if (star.z <= 0) {
                    star.x = Math.random() * cw - cx;
                    star.y = Math.random() * ch - cy;
                    star.z = cw;
                }
                const x = cx + (star.x / star.z) * cw;
                const y = cy + (star.y / star.z) * cw;
                const r = (1 - star.z / cw) * 2;
                
                ctx.fillStyle = "rgba(255, 255, 255, " + (1 - star.z / cw) + ")";
                ctx.beginPath();
                ctx.arc(x, y, r, 0, Math.PI * 2);
                ctx.fill();
            }
            requestAnimationFrame(draw);
        }
        
        draw();
        window.addEventListener('resize', () => { 
            cw = canvas.width = window.innerWidth; 
            ch = canvas.height = window.innerHeight; 
        });
    </script>
